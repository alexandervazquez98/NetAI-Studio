# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL
POSTGRES_DB=netai
POSTGRES_USER=netai
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# MCP Server
MCP_SERVER_HOST=mcp-server
MCP_SERVER_PORT=8001

# Análisis automático (cron-like)
ANALYSIS_INTERVAL_MINUTES=15
ANALYSIS_ENABLED=false

# Seguridad — Config Agent
CONFIG_AGENT_DRY_RUN_DEFAULT=true
CONFIG_AGENT_REQUIRE_APPROVAL=true